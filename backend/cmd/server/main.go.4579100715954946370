func (s *server) dashboardOverview(w http.ResponseWriter, r *http.Request) {
	summaries, workflow, err := s.loadCanonicalSummariesWithState("")
	if err != nil {
		internalError(w, err)
		return
	}

	highRisk := 0
	processing := 0
	closed := 0
	for _, item := range summaries {
		if item.Score >= 0.9 {
			highRisk++
		}
		st := workflow[item.ID]
		if st.Status == "核查中" {
			processing++
		}
		if st.Status == "已处置" {
			closed++
		}
	}

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data: map[string]interface{}{
			"kpi": map[string]interface{}{
				"high_risk_count":     highRisk,
				"new_clue_count":      len(summaries),
				"processing_count":    processing,
				"closed_count":        closed,
				"false_positive_rate": 0.0,
			},
		},
		TraceID: traceID(),
	})
}

func (s *server) dashboardTrend(w http.ResponseWriter, r *http.Request) {
	summaries, _, err := s.loadCanonicalSummariesWithState("")
	if err != nil {
		internalError(w, err)
		return
	}

	type group struct {
		Total    int
		HighRisk int
	}
	groups := map[string]group{}
	for _, item := range summaries {
		key := ""
		if len(item.ID) >= 8 {
			parts := strings.Split(item.ID, "-")
			if len(parts) == 3 {
				dt := parts[2]
				key = dt[0:4] + "-" + dt[4:6] + "-" + dt[6:8]
			}
		}
		if key == "" {
			key = time.Now().Format("2006-01-02")
		}
		val := groups[key]
		val.Total++
		if item.Score >= 0.9 {
			val.HighRisk++
		}
		groups[key] = val
	}

	dates := make([]string, 0, len(groups))
	for date := range groups {
		dates = append(dates, date)
	}
	slices.Sort(dates)

	points := make([]map[string]interface{}, 0, len(dates))
	for _, date := range dates {
		points = append(points, map[string]interface{}{
			"date":      date,
			"total":     groups[date].Total,
			"high_risk": groups[date].HighRisk,
		})
	}

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data:    points,
		TraceID: traceID(),
	})
}

func (s *server) dashboardTypeDistribution(w http.ResponseWriter, r *http.Request) {
	summaries, _, err := s.loadCanonicalSummariesWithState("")
	if err != nil {
		internalError(w, err)
		return
	}
	groups := map[string]int{}
	for _, item := range summaries {
		groups[item.Type]++
	}
	result := make([]map[string]interface{}, 0, len(groups))
	for key, val := range groups {
		result = append(result, map[string]interface{}{"type": key, "value": val})
	}
	slices.SortFunc(result, func(a, b map[string]interface{}) int {
		return cmp.Compare(a["type"].(string), b["type"].(string))
	})

	writeJSON(w, http.StatusOK, apiResponse{Code: "0", Message: "OK", Data: result, TraceID: traceID()})
}

func (s *server) clues(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		methodNotAllowed(w)
		return
	}

	filters := clueFilters{
		Keyword:      strings.TrimSpace(r.URL.Query().Get("keyword")),
		Status:       strings.TrimSpace(r.URL.Query().Get("status")),
		MarkTag:      strings.TrimSpace(r.URL.Query().Get("mark_tag")),
		Distribute:   strings.TrimSpace(r.URL.Query().Get("distribute")),
		DataDateFrom: strings.TrimSpace(r.URL.Query().Get("data_date_from")),
		DataDateTo:   strings.TrimSpace(r.URL.Query().Get("data_date_to")),
		SortBy:       strings.TrimSpace(r.URL.Query().Get("sort_by")),
		SortOrder:    strings.TrimSpace(r.URL.Query().Get("sort_order")),
	}
	if raw := strings.TrimSpace(r.URL.Query().Get("score_min")); raw != "" {
		if v, err := strconv.ParseFloat(raw, 64); err == nil {
			filters.ScoreMin = &v
		}
	}
	if raw := strings.TrimSpace(r.URL.Query().Get("score_max")); raw != "" {
		if v, err := strconv.ParseFloat(raw, 64); err == nil {
			filters.ScoreMax = &v
		}
	}
	page := 1
	pageSize := 20
	if raw := strings.TrimSpace(r.URL.Query().Get("page")); raw != "" {
		if parsed, err := strconv.Atoi(raw); err == nil && parsed > 0 {
			page = parsed
		}
	}
	if raw := strings.TrimSpace(r.URL.Query().Get("page_size")); raw != "" {
		if parsed, err := strconv.Atoi(raw); err == nil && parsed > 0 {
			pageSize = parsed
		}
	}
	if pageSize > 200 {
		pageSize = 200
	}

	summaries, total, err := s.loadSummariesPage(filters, page, pageSize)
	if err != nil {
		internalError(w, err)
		return
	}
	ids := make([]string, 0, len(summaries))
	for _, item := range summaries {
		ids = append(ids, item.ID)
	}
	if err := s.ensureWorkflowRows(ids); err != nil {
		internalError(w, err)
		return
	}
	workflow, err := s.loadWorkflowMapByIDs(ids)
	if err != nil {
		internalError(w, err)
		return
	}
	latestFeedback, err := s.loadLatestFeedbackMap(ids)
	if err != nil {
		internalError(w, err)
		return
	}

	list := make([]map[string]interface{}, 0, len(summaries))
	for _, item := range summaries {
		st := workflow[item.ID]
		fb := latestFeedback[item.ID]
		list = append(list, map[string]interface{}{
			"id":                item.ID,
			"type":              item.Type,
			"qklx":              item.Qklx.String,
			"summary":           item.Summary,
			"msisdn_1":          item.Msisdn1,
			"msisdn_2":          item.Msisdn2,
			"score":             item.Score,
			"update_time":       item.UpdateTime,
			"data_date":         item.DataDate,
			"status":            resolveStatus(st.Status, fb.Feedback != ""),
			"level":             st.Level.String,
			"feedback":          fb.Feedback,
			"feedback_time":     fb.FeedbackTime,
			"feedback_username": fb.FeedbackUserName.String,
			"remark":            st.Remark.String,
			"mark_tag":          st.MarkTag.String,
			"distribute":        st.Distribute.String,
		})
	}

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data: map[string]interface{}{
			"total":     total,
			"page":      page,
			"page_size": pageSize,
			"list":      list,
		},
		TraceID: traceID(),
	})
}

func (s *server) cluesFilterOptions(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		methodNotAllowed(w)
		return
	}

	statuses := make([]string, 0, 16)
	statusRows, err := s.bizDB().Query(
		`SELECT DISTINCT status FROM ` + s.bizTable("nb_tab_grjd_workflow_state") + ` WHERE status IS NOT NULL AND TRIM(status) <> '' ORDER BY status`,
	)
	if err == nil {
		defer statusRows.Close()
		for statusRows.Next() {
			var v sql.NullString
			if scanErr := statusRows.Scan(&v); scanErr == nil {
				val := strings.TrimSpace(v.String)
				if val != "" {
					statuses = append(statuses, val)
				}
			}
		}
	}

	distributes := make([]string, 0, 64)
	distributeRows, err := s.bizDB().Query(
		`SELECT DISTINCT distribute FROM ` + s.bizTable("nb_tab_grjd_workflow_state") + ` WHERE distribute IS NOT NULL AND TRIM(distribute) <> '' ORDER BY distribute`,
	)
	if err == nil {
		defer distributeRows.Close()
		for distributeRows.Next() {
			var v sql.NullString
			if scanErr := distributeRows.Scan(&v); scanErr == nil {
				val := strings.TrimSpace(v.String)
				if val != "" {
					distributes = append(distributes, val)
				}
			}
		}
	}

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data: map[string]interface{}{
			"status_options":     statuses,
			"distribute_options": distributes,
		},
		TraceID: traceID(),
	})
}

func (s *server) cluesSubRoutes(w http.ResponseWriter, r *http.Request) {
	switch {
	case strings.HasSuffix(r.URL.Path, "/detail") && r.Method == http.MethodGet:
		s.clueDetail(w, r)
	case strings.HasSuffix(r.URL.Path, "/feedbacks") && r.Method == http.MethodGet:
		s.clueFeedbacks(w, r)
	case strings.HasSuffix(r.URL.Path, "/messages") && r.Method == http.MethodGet:
		s.clueMessages(w, r)
	case strings.HasSuffix(r.URL.Path, "/action") && r.Method == http.MethodPost:
		s.clueAction(w, r)
	default:
		methodNotAllowed(w)
	}
}

func (s *server) clueDetail(w http.ResponseWriter, r *http.Request) {
	clueID := pathSegment(r.URL.Path, 3)
	if clueID == "" {
		badRequest(w, "invalid clue id")
		return
	}

	target, err := s.loadSummaryByID(clueID)
	if err != nil {
		internalError(w, err)
		return
	}
	if target == nil {
		notFound(w, "clue not found")
		return
	}
	if err := s.ensureWorkflowRows([]string{target.ID}); err != nil {
		internalError(w, err)
		return
	}
	workflow, err := s.loadWorkflowMapByIDs([]string{target.ID})
	if err != nil {
		internalError(w, err)
		return
	}
	st := workflow[target.ID]
	latestFeedback, err := s.loadLatestFeedbackMap([]string{clueID})
	if err != nil {
		internalError(w, err)
		return
	}
	fb := latestFeedback[target.ID]

	data := map[string]interface{}{
		"id":                target.ID,
		"type":              target.Type,
		"msisdn_1":          target.Msisdn1,
		"msisdn_2":          target.Msisdn2,
		"cnt":               target.Cnt,
		"cnt_dt":            target.CntDt,
		"summary":           target.Summary,
		"score":             target.Score,
		"qklx":              target.Qklx.String,
		"label2":            target.Label2.String,
		"user_id":           target.UserID.String,
		"user_name":         target.UserName.String,
		"status":            resolveStatus(st.Status, fb.Feedback != ""),
		"level":             st.Level.String,
		"feedback":          fb.Feedback,
		"feedback_time":     fb.FeedbackTime,
		"feedback_username": fb.FeedbackUserName.String,
		"remark":            st.Remark.String,
		"mark_tag":          st.MarkTag.String,
		"distribute":        st.Distribute.String,
		"update_time":       target.UpdateTime,
		"data_date":         target.DataDate,
	}

	writeJSON(w, http.StatusOK, apiResponse{Code: "0", Message: "OK", Data: data, TraceID: traceID()})
}

func (s *server) clueFeedbacks(w http.ResponseWriter, r *http.Request) {
	clueID := pathSegment(r.URL.Path, 3)
	if clueID == "" {
		badRequest(w, "invalid clue id")
		return
	}

	canonical := canonicalID(clueID)
	reversed := reverseID(canonical)
	rows, err := s.bizDB().Query(`
		SELECT clue_id, feedback_content, DATE_FORMAT(feedback_time, '%Y-%m-%d %H:%i:%s'), feedback_userId, feedback_username, remark
		FROM `+s.bizTable("nb_tab_grjd_feedback_history")+`
		WHERE clue_id IN (?, ?)
		ORDER BY feedback_time ASC`, canonical, reversed)
	if err != nil {
		internalError(w, err)
		return
	}
	defer rows.Close()

	list := make([]map[string]interface{}, 0)
	for rows.Next() {
		var item feedbackHistoryRow
		if err := rows.Scan(&item.ID, &item.Feedback, &item.FeedbackTime, &item.FeedbackUserID, &item.FeedbackUserName, &item.Remark); err != nil {
			internalError(w, err)
			return
		}
