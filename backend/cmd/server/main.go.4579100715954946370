func (s *server) dbTables(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		methodNotAllowed(w)
		return
	}
	dbKey := strings.ToLower(strings.TrimSpace(r.URL.Query().Get("db")))
	if dbKey == "" {
		dbKey = "sdata"
	}

	var db *sql.DB
	schema := ""
	switch dbKey {
	case "sdata":
		db = s.db
		schema = ""
	case "wxzdb":
		if s.externalDB != nil {
			db = s.externalDB
			schema = ""
		} else {
			db = s.db
			schema = strings.TrimSpace(runtimeConfig.ExternalMySQL.Database)
			if schema == "" {
				schema = "wxzdb"
			}
		}
	default:
		badRequest(w, "db must be sdata or wxzdb")
		return
	}

	query := "SHOW TABLES"
	if schema != "" {
		query = fmt.Sprintf("SHOW TABLES FROM `%s`", schema)
	}

	rows, err := db.Query(query)
	if err != nil {
		internalError(w, err)
		return
	}
	defer rows.Close()

	tables := make([]string, 0)
	for rows.Next() {
		var name string
		if err := rows.Scan(&name); err != nil {
			internalError(w, err)
			return
		}
		tables = append(tables, name)
	}
	if err := rows.Err(); err != nil {
		internalError(w, err)
		return
	}
	allowed := s.allowedTablesSet(dbKey)
	if len(allowed) > 0 {
		filtered := make([]string, 0, len(tables))
		for _, name := range tables {
			if allowed[name] {
				filtered = append(filtered, name)
			}
		}
		tables = filtered
	}
	slices.Sort(tables)

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data: map[string]interface{}{
			"db":     dbKey,
			"tables": tables,
		},
		TraceID: traceID(),
	})
}

var mysqlTableNamePattern = regexp.MustCompile(`^[A-Za-z0-9_]+$`)

func (s *server) dbTableRows(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		methodNotAllowed(w)
		return
	}
	dbKey := strings.ToLower(strings.TrimSpace(r.URL.Query().Get("db")))
	if dbKey == "" {
		dbKey = "sdata"
	}

	var db *sql.DB
	schema := ""
	switch dbKey {
	case "sdata":
		db = s.db
		schema = ""
	case "wxzdb":
		if s.externalDB != nil {
			db = s.externalDB
			schema = ""
		} else {
			db = s.db
			schema = strings.TrimSpace(runtimeConfig.ExternalMySQL.Database)
			if schema == "" {
				schema = "wxzdb"
			}
		}
	default:
		badRequest(w, "db must be sdata or wxzdb")
		return
	}

	tableName := strings.TrimSpace(pathSegment(r.URL.Path, 4))
	if tableName == "" || !mysqlTableNamePattern.MatchString(tableName) {
		badRequest(w, "invalid table name")
		return
	}
	if !s.isTableAllowed(dbKey, tableName) {
		notFound(w, "table not allowed")
		return
	}

	filterField := strings.TrimSpace(r.URL.Query().Get("filter_field"))
	filterValue := strings.TrimSpace(r.URL.Query().Get("filter_value"))
	if filterField != "" && !mysqlTableNamePattern.MatchString(filterField) {
		badRequest(w, "invalid filter field")
		return
	}

	page := 1
	pageSize := 20
	if raw := strings.TrimSpace(r.URL.Query().Get("page")); raw != "" {
		if _, err := fmt.Sscanf(raw, "%d", &page); err != nil || page < 1 {
			page = 1
		}
	}
	if raw := strings.TrimSpace(r.URL.Query().Get("page_size")); raw != "" {
		if _, err := fmt.Sscanf(raw, "%d", &pageSize); err != nil || pageSize < 1 {
			pageSize = 20
		}
	}
	if pageSize > 200 {
		pageSize = 200
	}
	offset := (page - 1) * pageSize

	tableExpr := fmt.Sprintf("`%s`", tableName)
	if schema != "" {
		tableExpr = fmt.Sprintf("`%s`.`%s`", schema, tableName)
	}

	whereClause := ""
	countArgs := make([]interface{}, 0)
	if filterField != "" && filterValue != "" {
		whereClause = fmt.Sprintf(" WHERE `%s` LIKE ?", filterField)
		countArgs = append(countArgs, "%"+filterValue+"%")
	}

	countQuery := fmt.Sprintf("SELECT COUNT(1) FROM %s%s", tableExpr, whereClause)
	var total int
	if err := db.QueryRow(countQuery, countArgs...).Scan(&total); err != nil {
		internalError(w, err)
		return
	}

	query := fmt.Sprintf("SELECT * FROM %s%s LIMIT ? OFFSET ?", tableExpr, whereClause)
	rowArgs := make([]interface{}, 0, len(countArgs)+2)
	rowArgs = append(rowArgs, countArgs...)
	rowArgs = append(rowArgs, pageSize, offset)
	rows, err := db.Query(query, rowArgs...)
	if err != nil {
		internalError(w, err)
		return
	}
	defer rows.Close()

	columns, err := rows.Columns()
	if err != nil {
		internalError(w, err)
		return
	}
	columnTypes, _ := rows.ColumnTypes()

	list := make([]map[string]interface{}, 0)
	for rows.Next() {
		values := make([]interface{}, len(columns))
		scans := make([]interface{}, len(columns))
		for i := range values {
			scans[i] = &values[i]
		}
		if err := rows.Scan(scans...); err != nil {
			internalError(w, err)
			return
		}

		item := map[string]interface{}{}
		for i, col := range columns {
			val := values[i]
			switch v := val.(type) {
			case []byte:
				typeName := ""
				if i < len(columnTypes) {
					typeName = strings.ToUpper(columnTypes[i].DatabaseTypeName())
				}
				if typeName == "BIT" && len(v) > 0 {
					acc := 0
					for _, b := range v {
						acc = (acc << 8) | int(b)
					}
					item[col] = acc
				} else {
					item[col] = string(v)
				}
			default:
				item[col] = v
			}
		}
		list = append(list, item)
	}
	if err := rows.Err(); err != nil {
		internalError(w, err)
		return
	}

	primaryKeys, err := s.getPrimaryKeyColumns(db, schema, tableName)
	if err != nil {
		primaryKeys = []string{}
	}

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data: map[string]interface{}{
			"db":           dbKey,
			"table":        tableName,
			"columns":      columns,
			"primary_keys": primaryKeys,
			"rows":         list,
