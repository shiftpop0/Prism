	}

	writeJSON(w, http.StatusOK, apiResponse{Code: "0", Message: "OK", Data: list, TraceID: traceID()})
}

func (s *server) clueMessages(w http.ResponseWriter, r *http.Request) {
	clueID := pathSegment(r.URL.Path, 3)
	if clueID == "" {
		badRequest(w, "invalid clue id")
		return
	}

	canonical := canonicalID(clueID)
	reversed := reverseID(canonical)

	rows, err := s.db.Query(
		`SELECT id, capture_time, msisdn, calltype, message
         FROM nb_tab_grjd_message
         WHERE id IN (?, ?)
         ORDER BY capture_time ASC`,
		canonical, reversed,
	)
	if err != nil {
		internalError(w, err)
		return
	}
	defer rows.Close()

	byMessage := map[string]messageRow{}
	for rows.Next() {
		var item messageRow
		if err := rows.Scan(&item.ID, &item.CaptureTime, &item.Msisdn, &item.CallType, &item.Message); err != nil {
			internalError(w, err)
			return
		}

		prev, exists := byMessage[item.Message]
		if !exists {
			byMessage[item.Message] = item
			continue
		}

		if prev.CallType == "2" && item.CallType == "1" {
			byMessage[item.Message] = item
			continue
		}

		if prev.CallType == item.CallType && item.CaptureTime < prev.CaptureTime {
			byMessage[item.Message] = item
		}
	}
	if err := rows.Err(); err != nil {
		internalError(w, err)
		return
	}

	list := make([]messageRow, 0, len(byMessage))
	for _, item := range byMessage {
		list = append(list, item)
	}
	slices.SortFunc(list, func(a, b messageRow) int {
		return cmp.Compare(a.CaptureTime, b.CaptureTime)
	})

	resp := make([]map[string]interface{}, 0, len(list))
	for _, item := range list {
		resp = append(resp, map[string]interface{}{
			"sender":       item.Msisdn,
			"capture_time": item.CaptureTime,
			"message":      item.Message,
		})
	}

	writeJSON(w, http.StatusOK, apiResponse{Code: "0", Message: "OK", Data: resp, TraceID: traceID()})
}

