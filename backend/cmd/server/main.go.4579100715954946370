func schemaFromDSN(dsn string) string {
	raw := strings.TrimSpace(dsn)
	if raw == "" {
		return ""
	}
	slash := strings.LastIndex(raw, "/")
	if slash < 0 || slash+1 >= len(raw) {
		return ""
	}
	part := raw[slash+1:]
	if q := strings.Index(part, "?"); q >= 0 {
		part = part[:q]
	}
	return strings.TrimSpace(part)
}

func (s *server) validateExternalDBConfig() error {
	extDSN := strings.TrimSpace(runtimeConfig.ExternalMySQL.DSN)
	extDB := strings.TrimSpace(runtimeConfig.ExternalMySQL.Database)
	dsnDB := schemaFromDSN(extDSN)

	if extDSN != "" && extDB == "" && dsnDB != "" {
		// Keep behavior config-driven by deriving empty database field from the same config object.
		runtimeConfig.ExternalMySQL.Database = dsnDB
		extDB = dsnDB
	}

	if extDSN != "" && extDB != "" && dsnDB != "" && !strings.EqualFold(extDB, dsnDB) {
		return fmt.Errorf(
			"external_mysql config mismatch: database=%q but dsn schema=%q; please align prism-config.json",
			extDB, dsnDB,
		)
	}
	return nil
}

func pathSegment(path string, idx int) string {
	parts := strings.Split(strings.Trim(path, "/"), "/")
	if idx >= 0 && idx < len(parts) {
		return parts[idx]
	}
	return ""
}

func nonEmpty(val string, fallback string) string {
	if strings.TrimSpace(val) == "" {
		return fallback
	}
	return val
}

func resolveStatus(current string, hasFeedback bool) string {
	st := nonEmpty(current, "待核查")
	if st == "已处置" {
		return st
	}
	if hasFeedback {
		return "已反馈"
	}
	return st
}

func canonicalID(id string) string {
	a, b, dt, ok := splitID(id)
	if !ok {
		return id
	}
	if lessOrEqualNumericString(a, b) {
		return a + "-" + b + "-" + dt
	}
	return b + "-" + a + "-" + dt
}

func reverseID(id string) string {
	a, b, dt, ok := splitID(id)
	if !ok {
		return id
	}
	return b + "-" + a + "-" + dt
}

func splitID(id string) (string, string, string, bool) {
	parts := strings.Split(id, "-")
	if len(parts) != 3 {
		return "", "", "", false
	}
	return parts[0], parts[1], parts[2], true
}

func lessOrEqualNumericString(a, b string) bool {
	aTrim := strings.TrimLeft(a, "0")
	bTrim := strings.TrimLeft(b, "0")
	if aTrim == "" {
		aTrim = "0"
	}
	if bTrim == "" {
		bTrim = "0"
	}
	if len(aTrim) != len(bTrim) {
		return len(aTrim) < len(bTrim)
	}
	return aTrim <= bTrim
}

