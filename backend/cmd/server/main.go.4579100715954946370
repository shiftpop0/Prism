	_, _ = s.db.Exec(`ALTER TABLE nb_tab_grjd_summary MODIFY COLUMN update_time DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT 'updated at'`)
	_, _ = s.db.Exec(`ALTER TABLE nb_tab_grjd_summary MODIFY COLUMN dt DATE DEFAULT NULL COMMENT 'data date'`)
	_, _ = s.db.Exec(`ALTER TABLE nb_tab_grjd_summary ADD PRIMARY KEY (id)`)

	return nil
}

func (s *server) hasColumn(tableName, columnName string) (bool, error) {
	var count int
	schema := s.bizSchemaName()
	if schema == "" {
		err := s.bizDB().QueryRow(`
			SELECT COUNT(1)
			FROM information_schema.COLUMNS
			WHERE TABLE_SCHEMA = DATABASE()
			AND TABLE_NAME = ?
			AND COLUMN_NAME = ?`, tableName, columnName).Scan(&count)
		if err != nil {
			return false, err
		}
		return count > 0, nil
	}
	err := s.bizDB().QueryRow(`
		SELECT COUNT(1)
		FROM information_schema.COLUMNS
		WHERE TABLE_SCHEMA = ?
		AND TABLE_NAME = ?
		AND COLUMN_NAME = ?`, schema, tableName, columnName).Scan(&count)
	if err != nil {
		return false, err
	}
	return count > 0, nil
}

func (s *server) ensureFeedbackHistoryTable() error {
	feedbackHistoryTable := s.bizTable("nb_tab_grjd_feedback_history")
	_, err := s.bizDB().Exec(`
		CREATE TABLE IF NOT EXISTS ` + feedbackHistoryTable + ` (
			feedback_id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
			clue_id VARCHAR(64) NOT NULL,
			feedback_content TEXT NOT NULL,
			feedback_userId VARCHAR(64) NULL,
			feedback_username VARCHAR(64) NULL,
			remark TEXT NULL,
			feedback_time DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
			KEY idx_feedback_id_time (clue_id, feedback_time)
		) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4`)
	if err != nil {
		return err
	}

	hasID, err := s.hasColumn("nb_tab_grjd_feedback_history", "id")
	if err != nil {
		return err
	}
	hasClueID, err := s.hasColumn("nb_tab_grjd_feedback_history", "clue_id")
	if err != nil {
		return err
	}
	if hasID && !hasClueID {
		if _, err := s.bizDB().Exec(`ALTER TABLE ` + feedbackHistoryTable + ` CHANGE COLUMN id clue_id VARCHAR(64) NOT NULL`); err != nil {
			return err
		}
	}

	hasFeedbackUserID, err := s.hasColumn("nb_tab_grjd_feedback_history", "feedback_userId")
	if err != nil {
		return err
	}
	if !hasFeedbackUserID {
		if _, err := s.bizDB().Exec(`ALTER TABLE ` + feedbackHistoryTable + ` ADD COLUMN feedback_userId VARCHAR(64) NULL AFTER feedback_content`); err != nil {
			return err
		}
	}

	hasFeedbackUserName, err := s.hasColumn("nb_tab_grjd_feedback_history", "feedback_username")
	if err != nil {
		return err
	}
	if !hasFeedbackUserName {
		if _, err := s.bizDB().Exec(`ALTER TABLE ` + feedbackHistoryTable + ` ADD COLUMN feedback_username VARCHAR(64) NULL AFTER feedback_userId`); err != nil {
			return err
		}
	}

	hasRemark, err := s.hasColumn("nb_tab_grjd_feedback_history", "remark")
	if err != nil {
		return err
	}
	if !hasRemark {
		if _, err := s.bizDB().Exec(`ALTER TABLE ` + feedbackHistoryTable + ` ADD COLUMN remark TEXT NULL AFTER feedback_username`); err != nil {
			return err
		}
	}

	_, _ = s.bizDB().Exec(`ALTER TABLE ` + feedbackHistoryTable + ` DROP INDEX idx_feedback_id_time`)
	_, _ = s.bizDB().Exec(`ALTER TABLE ` + feedbackHistoryTable + ` ADD INDEX idx_feedback_id_time (clue_id, feedback_time)`)

	return nil
}

