func main() {
	log.SetOutput(os.Stdout)
	runtimeConfig = loadAppConfig()
	if runtimeConfigPath != "" {
		log.Printf("config loaded from: %s", runtimeConfigPath)
	} else {
		log.Printf("config loaded from: (not found, using zero-value defaults)")
	}

	srv := &server{}
	if err := srv.initMySQL(); err != nil {
		log.Fatalf("mysql init failed: %v", err)
	}

	mux := http.NewServeMux()
	mux.HandleFunc("/api/v1", srv.apiIndex)
	mux.HandleFunc("/api/v1/health", srv.health)
	mux.HandleFunc("/api/v1/dashboard/overview", srv.dashboardOverview)
	mux.HandleFunc("/api/v1/dashboard/trend", srv.dashboardTrend)
	mux.HandleFunc("/api/v1/dashboard/type-distribution", srv.dashboardTypeDistribution)
	mux.HandleFunc("/api/v1/clues", srv.clues)
	mux.HandleFunc("/api/v1/clues/filter-options", srv.cluesFilterOptions)
	mux.HandleFunc("/api/v1/clues/", srv.cluesSubRoutes)
	mux.HandleFunc("/api/v1/dialogue/agent-spec", srv.dialogueAgentSpec)
	mux.HandleFunc("/api/v1/dialogue/snapshot", srv.dialogueSnapshot)
	mux.HandleFunc("/api/v1/dialogue/sessions/", srv.dialogueMessage)
	mux.HandleFunc("/api/v1/reports/generate", srv.reportGenerate)
	mux.HandleFunc("/api/v1/db/tables", srv.dbTables)
	mux.HandleFunc("/api/v1/db/tables/", srv.dbTableRows)
	mux.HandleFunc("/api/v1/db/import-feedback-to-history", srv.importFeedbackToHistory)
	mux.HandleFunc("/api/v1/db/import-distribute-to-workflow", srv.importDistributeToWorkflow)
	mux.HandleFunc("/api/v1/db/init-workflow-state", srv.initWorkflowState)
	registerFrontendRoutes(mux)

	addr := envOrDefault("SERVER_ADDR", ":8080")
	log.Printf("Prism API listening on %s", addr)
	if err := http.ListenAndServe(addr, withCORS(mux)); err != nil {
		log.Fatal(err)
	}
}

