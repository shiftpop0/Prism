func (s *server) syncWorkflowDistribute() error {
	_, _, _, err := s.syncWorkflowDistributeWithStats()
	return err
}

func (s *server) syncWorkflowDistributeWithStats() (int64, int64, int64, error) {
	resInsert, err := s.bizDB().Exec(`
		INSERT INTO ` + s.bizTable("nb_tab_grjd_workflow_state") + ` (id, status, level, distribute)
		SELECT clue_id, '待核查', level, tag
		FROM ` + s.bizTable("grjd_distribute") + `
		ON DUPLICATE KEY UPDATE
			level = VALUES(level),
			distribute = VALUES(distribute)`)
	if err != nil {
		return 0, 0, 0, err
	}
	insertOrUpdate, _ := resInsert.RowsAffected()

	resDistribute, err := s.bizDB().Exec(`
		UPDATE ` + s.bizTable("nb_tab_grjd_workflow_state") + ` w
		LEFT JOIN ` + s.bizTable("grjd_distribute") + ` d ON w.id = d.clue_id
		SET w.distribute = COALESCE(d.tag, '')`)
	if err != nil {
		return 0, 0, 0, err
	}
	updatedDistribute, _ := resDistribute.RowsAffected()

	resLevel, err := s.bizDB().Exec(`
		UPDATE ` + s.bizTable("nb_tab_grjd_workflow_state") + ` w
		JOIN ` + s.bizTable("grjd_distribute") + ` d ON w.id = d.clue_id
		SET w.level = d.level`)
	if err != nil {
		return 0, 0, 0, err
	}
	updatedLevel, _ := resLevel.RowsAffected()
	return insertOrUpdate, updatedDistribute, updatedLevel, nil
}

func (s *server) rebuildWorkflowStateFromSummary() (int64, int64, error) {
	if err := s.ensureWorkflowTable(); err != nil {
		return 0, 0, err
	}
	if err := s.ensureDistributeTable(); err != nil {
		return 0, 0, err
	}
	if err := s.ensureFeedbackHistoryTable(); err != nil {
		return 0, 0, err
	}

	summaryRows, err := s.db.Query(`SELECT id FROM nb_tab_grjd_summary`)
	if err != nil {
		return 0, 0, err
	}
	defer summaryRows.Close()

	summaryIDs := make([]string, 0, 4096)
	for summaryRows.Next() {
		var id string
		if err := summaryRows.Scan(&id); err != nil {
			return 0, 0, err
		}
		summaryIDs = append(summaryIDs, canonicalID(id))
	}
	if err := summaryRows.Err(); err != nil {
		return 0, 0, err
	}
	if len(summaryIDs) == 0 {
		return 0, 0, nil
	}

	existingRows, err := s.bizDB().Query(`SELECT id FROM ` + s.bizTable("nb_tab_grjd_workflow_state"))
	if err != nil {
		return 0, 0, err
	}
	defer existingRows.Close()
	existing := map[string]bool{}
	for existingRows.Next() {
		var id string
		if err := existingRows.Scan(&id); err != nil {
			return 0, 0, err
		}
		existing[canonicalID(id)] = true
	}
	if err := existingRows.Err(); err != nil {
		return 0, 0, err
	}

	feedbackRows, err := s.bizDB().Query(`SELECT DISTINCT clue_id FROM ` + s.bizTable("nb_tab_grjd_feedback_history"))
	if err != nil {
		return 0, 0, err
	}
	defer feedbackRows.Close()
	feedbackSet := map[string]bool{}
	for feedbackRows.Next() {
		var clueID string
		if err := feedbackRows.Scan(&clueID); err != nil {
			return 0, 0, err
		}
		feedbackSet[canonicalID(clueID)] = true
	}
	if err := feedbackRows.Err(); err != nil {
		return 0, 0, err
	}

	type distributeInfo struct {
		level      sql.NullString
		distribute string
	}
	distributeRows, err := s.bizDB().Query(`SELECT clue_id, level, tag FROM ` + s.bizTable("grjd_distribute"))
	if err != nil {
		return 0, 0, err
	}
	defer distributeRows.Close()
	distributeMap := map[string]distributeInfo{}
	for distributeRows.Next() {
		var clueID string
		var level sql.NullString
		var tag sql.NullString
		if err := distributeRows.Scan(&clueID, &level, &tag); err != nil {
			return 0, 0, err
		}
		distributeMap[canonicalID(clueID)] = distributeInfo{
			level:      level,
			distribute: strings.TrimSpace(tag.String),
		}
	}
	if err := distributeRows.Err(); err != nil {
		return 0, 0, err
	}

	tx, err := s.bizDB().Begin()
	if err != nil {
		return 0, 0, err
	}
	committed := false
	defer func() {
		if !committed {
			_ = tx.Rollback()
		}
	}()

	stmt, err := tx.Prepare(`
		INSERT INTO ` + s.bizTable("nb_tab_grjd_workflow_state") + ` (id, status, level, distribute, updated_at)
		VALUES (?, ?, ?, ?, NOW())
		ON DUPLICATE KEY UPDATE
			status = VALUES(status),
			level = VALUES(level),
			distribute = VALUES(distribute),
			updated_at = VALUES(updated_at)`)
	if err != nil {
		return 0, 0, err
	}
	defer stmt.Close()

	inserted := int64(0)
	updated := int64(0)
	for _, id := range summaryIDs {
		status := "待核查"
		if feedbackSet[id] {
			status = "已反馈"
		}
		info := distributeMap[id]
		levelArg := interface{}(nil)
		if info.level.Valid && strings.TrimSpace(info.level.String) != "" {
			levelArg = strings.TrimSpace(info.level.String)
		}
		if _, err := stmt.Exec(id, status, levelArg, info.distribute); err != nil {
			return inserted, updated, err
		}
		updated++
		if !existing[id] {
			inserted++
		}
	}
	if err := tx.Commit(); err != nil {
		return inserted, updated, err
	}
	committed = true
	return inserted, updated, nil
}

func (s *server) loadLatestFeedbackMap(ids []string) (map[string]feedbackHistoryRow, error) {
	result := map[string]feedbackHistoryRow{}
	if len(ids) == 0 {
		return result, nil
	}

	idSet := map[string]bool{}
	for _, id := range ids {
		canonical := canonicalID(id)
		idSet[canonical] = true
		idSet[reverseID(canonical)] = true
	}

	placeholders := make([]string, 0, len(idSet))
	args := make([]interface{}, 0, len(idSet))
	for id := range idSet {
		placeholders = append(placeholders, "?")
		args = append(args, id)
	}

	query := fmt.Sprintf(`
		SELECT clue_id, feedback_content, DATE_FORMAT(feedback_time, '%%Y-%%m-%%d %%H:%%i:%%s'), feedback_username
		FROM %s
		WHERE clue_id IN (%s)
		ORDER BY feedback_time DESC`, s.bizTable("nb_tab_grjd_feedback_history"), strings.Join(placeholders, ","))

	rows, err := s.bizDB().Query(query, args...)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	for rows.Next() {
		var item feedbackHistoryRow
		if err := rows.Scan(&item.ID, &item.Feedback, &item.FeedbackTime, &item.FeedbackUserName); err != nil {
			return nil, err
		}
		canonical := canonicalID(item.ID)
		item.ID = canonical
		if _, exists := result[canonical]; !exists {
			result[canonical] = item
		}
	}

	return result, rows.Err()
}

func (s *server) loadCanonicalSummariesWithState(keyword string) ([]summaryRow, map[string]workflowState, error) {
	rows, err := s.db.Query(`
	SELECT id, type, msisdn_1, msisdn_2, cnt, cnt_dt, summary, score,
		 qklx, label2, user_id, user_name, status,
		 COALESCE(DATE_FORMAT(update_time, '%Y-%m-%d %H:%i:%s'), '') AS update_time,
		 COALESCE(
			 DATE_FORMAT(dt, '%Y-%m-%d'),
			 CASE
				 WHEN CHAR_LENGTH(TRIM(CAST(dt AS CHAR))) = 8
				 THEN CONCAT(
					 SUBSTRING(TRIM(CAST(dt AS CHAR)), 1, 4), '-',
					 SUBSTRING(TRIM(CAST(dt AS CHAR)), 5, 2), '-',
					 SUBSTRING(TRIM(CAST(dt AS CHAR)), 7, 2)
				 )
				 WHEN CHAR_LENGTH(TRIM(CAST(dt AS CHAR))) >= 10
				 THEN SUBSTRING(TRIM(CAST(dt AS CHAR)), 1, 10)
				 ELSE ''
			 END,
			 ''
		 ) AS data_date
        FROM nb_tab_grjd_summary`)
	if err != nil {
		return nil, nil, err
	}
	defer rows.Close()

	grouped := map[string]summaryRow{}
	for rows.Next() {
		var item summaryRow
		if err := rows.Scan(
			&item.ID,
			&item.Type,
			&item.Msisdn1,
			&item.Msisdn2,
			&item.Cnt,
			&item.CntDt,
			&item.Summary,
			&item.Score,
			&item.Qklx,
			&item.Label2,
			&item.UserID,
			&item.UserName,
			&item.Status,
			&item.UpdateTime,
			&item.DataDate,
		); err != nil {
			return nil, nil, err
		}

		item.Msisdn1, item.Msisdn2 = canonicalPair(item.Msisdn1, item.Msisdn2)
		_, _, dt, ok := splitID(item.ID)
		if ok {
			item.ID = item.Msisdn1 + "-" + item.Msisdn2 + "-" + dt
		} else {
			item.ID = canonicalID(item.ID)
		}
		canonical := item.ID
		if keyword != "" {
			if !strings.Contains(canonical, keyword) &&
				!strings.Contains(item.Msisdn1, keyword) &&
				!strings.Contains(item.Msisdn2, keyword) &&
				!strings.Contains(item.Summary, keyword) {
				continue
			}
		}

		prev, exists := grouped[canonical]
		if !exists {
			grouped[canonical] = item
			continue
		}

		if item.UpdateTime > prev.UpdateTime {
			grouped[canonical] = item
		}
	}
	if err := rows.Err(); err != nil {
		return nil, nil, err
	}

	ids := make([]string, 0, len(grouped))
	list := make([]summaryRow, 0, len(grouped))
	for _, item := range grouped {
		ids = append(ids, item.ID)
		list = append(list, item)
	}
	slices.Sort(ids)
	slices.SortFunc(list, func(a, b summaryRow) int { return cmp.Compare(a.ID, b.ID) })

	state, err := s.loadWorkflowMap()
	if err != nil {
		return nil, nil, err
	}
	return list, state, nil
}

func (s *server) loadSummariesPage(filters clueFilters, page, pageSize int) ([]summaryRow, int, error) {
	if page < 1 {
		page = 1
	}
	if pageSize <= 0 {
		pageSize = 20
	}
	offset := (page - 1) * pageSize

	dataDateExpr := `COALESCE(
         DATE_FORMAT(s.dt, '%Y-%m-%d'),
         CASE
           WHEN CHAR_LENGTH(TRIM(CAST(s.dt AS CHAR))) = 8
           THEN CONCAT(
             SUBSTRING(TRIM(CAST(s.dt AS CHAR)), 1, 4), '-',
             SUBSTRING(TRIM(CAST(s.dt AS CHAR)), 5, 2), '-',
             SUBSTRING(TRIM(CAST(s.dt AS CHAR)), 7, 2)
           )
           WHEN CHAR_LENGTH(TRIM(CAST(s.dt AS CHAR))) >= 10
           THEN SUBSTRING(TRIM(CAST(s.dt AS CHAR)), 1, 10)
           ELSE ''
         END,
         ''
       )`

	coreWhereParts := make([]string, 0, 12)
	coreArgs := make([]interface{}, 0, 20)
	if filters.Keyword != "" {
		like := "%" + filters.Keyword + "%"
		coreWhereParts = append(coreWhereParts, "(s.id LIKE ? OR s.msisdn_1 LIKE ? OR s.msisdn_2 LIKE ? OR s.summary LIKE ? OR s.type LIKE ? OR s.qklx LIKE ?)")
		for i := 0; i < 6; i++ {
			coreArgs = append(coreArgs, like)
		}
	}
	if filters.ScoreMin != nil {
		coreWhereParts = append(coreWhereParts, "s.score >= ?")
		coreArgs = append(coreArgs, *filters.ScoreMin)
	}
	if filters.ScoreMax != nil {
		coreWhereParts = append(coreWhereParts, "s.score <= ?")
		coreArgs = append(coreArgs, *filters.ScoreMax)
	}
	if filters.DataDateFrom != "" {
		coreWhereParts = append(coreWhereParts, dataDateExpr+" >= ?")
		coreArgs = append(coreArgs, filters.DataDateFrom)
	}
	if filters.DataDateTo != "" {
		coreWhereParts = append(coreWhereParts, dataDateExpr+" <= ?")
		coreArgs = append(coreArgs, filters.DataDateTo)
	}
	coreWhere := ""
	if len(coreWhereParts) > 0 {
		coreWhere = " WHERE " + strings.Join(coreWhereParts, " AND ")
	}

	querySQL := `
SELECT s.id, s.type, s.msisdn_1, s.msisdn_2, s.cnt, s.cnt_dt, s.summary, s.score,
       s.qklx, s.label2, s.user_id, s.user_name, s.status,
       COALESCE(DATE_FORMAT(s.update_time, '%Y-%m-%d %H:%i:%s'), '') AS update_time,
       ` + dataDateExpr + ` AS data_date
 FROM nb_tab_grjd_summary s` + coreWhere + `
 ORDER BY s.update_time DESC
`
	rows, err := s.db.Query(querySQL, coreArgs...)
	if err != nil {
		return nil, 0, err
	}
	defer rows.Close()

	allRows := make([]summaryRow, 0, pageSize)
	for rows.Next() {
		var item summaryRow
		if err := rows.Scan(
			&item.ID, &item.Type, &item.Msisdn1, &item.Msisdn2, &item.Cnt, &item.CntDt,
			&item.Summary, &item.Score, &item.Qklx, &item.Label2, &item.UserID, &item.UserName,
			&item.Status, &item.UpdateTime, &item.DataDate,
		); err != nil {
			return nil, 0, err
		}
		item.Msisdn1, item.Msisdn2 = canonicalPair(item.Msisdn1, item.Msisdn2)
		item.ID = canonicalID(item.ID)
		allRows = append(allRows, item)
	}
	if err := rows.Err(); err != nil {
		return nil, 0, err
	}

	if len(allRows) == 0 {
		return []summaryRow{}, 0, nil
	}

	ids := make([]string, 0, len(allRows))
	for _, row := range allRows {
		ids = append(ids, row.ID)
	}
	if err := s.ensureWorkflowRows(ids); err != nil {
		return nil, 0, err
	}
	workflow, err := s.loadWorkflowMapByIDsChunked(ids, 500)
	if err != nil {
		return nil, 0, err
	}

	filtered := make([]summaryRow, 0, len(allRows))
	for _, row := range allRows {
		st := workflow[row.ID]
		statusVal := strings.TrimSpace(st.Status)
		if statusVal == "" {
			statusVal = "待核查"
		}
		markVal := strings.TrimSpace(st.MarkTag.String)
		distributeVal := strings.TrimSpace(st.Distribute.String)

		if filters.Status != "" && statusVal != filters.Status {
			continue
		}
		if filters.MarkTag != "" {
			if filters.MarkTag == "__EMPTY__" {
				if markVal != "" {
					continue
				}
			} else if markVal != filters.MarkTag {
				continue
			}
		}
		if filters.Distribute != "" {
			if filters.Distribute == "__EMPTY__" {
				if distributeVal != "" {
					continue
				}
			} else if distributeVal != filters.Distribute {
				continue
			}
		}
		filtered = append(filtered, row)
	}

	sortBy := strings.TrimSpace(filters.SortBy)
	sortOrder := strings.ToLower(strings.TrimSpace(filters.SortOrder))
	if sortOrder != "asc" && sortOrder != "desc" {
		sortOrder = "desc"
	}
	allowedSortBy := map[string]bool{
		"msisdn_1":   true,
		"msisdn_2":   true,
		"type":       true,
		"qklx":       true,
		"level":      true,
		"score":      true,
		"update_time": true,
		"status":     true,
		"distribute": true,
	}
	if !allowedSortBy[sortBy] {
		sortBy = "update_time"
		sortOrder = "desc"
	}
	sort.SliceStable(filtered, func(i, j int) bool {
		a := filtered[i]
		b := filtered[j]
		wa := workflow[a.ID]
		wb := workflow[b.ID]
		va := ""
		vb := ""
		cmp := 0
		switch sortBy {
		case "msisdn_1":
			va, vb = a.Msisdn1, b.Msisdn1
			cmp = strings.Compare(va, vb)
		case "msisdn_2":
			va, vb = a.Msisdn2, b.Msisdn2
			cmp = strings.Compare(va, vb)
		case "type":
			va, vb = a.Type, b.Type
			cmp = strings.Compare(va, vb)
		case "qklx":
			va, vb = a.Qklx.String, b.Qklx.String
			cmp = strings.Compare(va, vb)
		case "level":
			va, vb = wa.Level.String, wb.Level.String
			cmp = strings.Compare(va, vb)
		case "score":
			if a.Score < b.Score {
				cmp = -1
			} else if a.Score > b.Score {
				cmp = 1
			}
		case "status":
			sa := strings.TrimSpace(wa.Status)
			sb := strings.TrimSpace(wb.Status)
			if sa == "" {
				sa = "待核查"
			}
			if sb == "" {
				sb = "待核查"
			}
			cmp = strings.Compare(sa, sb)
		case "distribute":
			va, vb = wa.Distribute.String, wb.Distribute.String
			cmp = strings.Compare(va, vb)
		default:
			// Sort by data_date shown in list. Fallback to update_time then id for deterministic order.
			va, vb = a.DataDate, b.DataDate
			cmp = strings.Compare(va, vb)
			if cmp == 0 {
				cmp = strings.Compare(a.UpdateTime, b.UpdateTime)
			}
		}
		if cmp == 0 {
			cmp = strings.Compare(a.ID, b.ID)
		}
		if sortOrder == "asc" {
			return cmp < 0
		}
		return cmp > 0
	})

	total := len(filtered)
	if offset >= total {
		return []summaryRow{}, total, nil
	}
	end := offset + pageSize
	if end > total {
		end = total
	}
	return filtered[offset:end], total, nil
}

func (s *server) loadWorkflowMapByIDsChunked(ids []string, chunkSize int) (map[string]workflowState, error) {
	result := map[string]workflowState{}
	if len(ids) == 0 {
		return result, nil
	}
	if chunkSize <= 0 {
		chunkSize = 500
	}
	for start := 0; start < len(ids); start += chunkSize {
		end := start + chunkSize
		if end > len(ids) {
			end = len(ids)
		}
		part, err := s.loadWorkflowMapByIDs(ids[start:end])
		if err != nil {
			return nil, err
		}
		for k, v := range part {
			result[k] = v
		}
	}
	return result, nil
}

