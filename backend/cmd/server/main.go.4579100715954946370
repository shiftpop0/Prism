func registerFrontendRoutes(mux *http.ServeMux) {
	distDir := resolveStaticDir()
	if distDir == "" {
		log.Printf("frontend static dir not found, API-only mode")
		return
	}

	fileServer := http.FileServer(http.Dir(distDir))
	mux.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
		if strings.HasPrefix(r.URL.Path, "/api/") {
			notFound(w, "route not found")
			return
		}

		cleanPath := strings.TrimPrefix(path.Clean("/"+r.URL.Path), "/")
		target := filepath.Join(distDir, cleanPath)
		if cleanPath == "" {
			target = filepath.Join(distDir, "index.html")
		}
		if info, err := os.Stat(target); err == nil && !info.IsDir() {
			fileServer.ServeHTTP(w, r)
			return
		}
		http.ServeFile(w, r, filepath.Join(distDir, "index.html"))
	})
	log.Printf("frontend static serving enabled: %s", distDir)
}

func resolveStaticDir() string {
	candidates := []string{}
	if v := strings.TrimSpace(os.Getenv("PRISM_STATIC_DIR")); v != "" {
		candidates = append(candidates, v)
	}
	candidates = append(candidates, "../frontend/dist", "frontend/dist", "./dist")
	for _, c := range candidates {
		if info, err := os.Stat(c); err == nil && info.IsDir() {
			return c
		}
	}
	return ""
}

