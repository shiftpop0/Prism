func (s *server) getPrimaryKeyColumns(db *sql.DB, schema, tableName string) ([]string, error) {
	targetSchema := schema
	if targetSchema == "" {
		if err := db.QueryRow("SELECT DATABASE()").Scan(&targetSchema); err != nil {
			return nil, err
		}
	}

	rows, err := db.Query(`
		SELECT COLUMN_NAME
		FROM INFORMATION_SCHEMA.KEY_COLUMN_USAGE
		WHERE TABLE_SCHEMA = ? AND TABLE_NAME = ? AND CONSTRAINT_NAME = 'PRIMARY'
		ORDER BY ORDINAL_POSITION`, targetSchema, tableName)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	list := make([]string, 0)
	for rows.Next() {
		var name string
		if err := rows.Scan(&name); err != nil {
			return nil, err
		}
		list = append(list, name)
	}
	if err := rows.Err(); err != nil {
		return nil, err
	}
	return list, nil
}

func normalizeDateToCompact(raw string) string {
	val := strings.TrimSpace(raw)
	if val == "" {
		return ""
	}
	if len(val) >= 8 && strings.Count(val, "-") == 0 {
		return val[0:8]
	}
	if t, err := time.Parse("2006-01-02", val); err == nil {
		return t.Format("20060102")
	}
	if len(val) >= 10 {
		if t, err := time.Parse("2006-01-02 15:04:05", val[0:19]); err == nil {
			return t.Format("20060102")
		}
	}
	return ""
}

func composeClueID(phoneA, phoneB, dateRaw string) string {
	a := strings.TrimSpace(phoneA)
	b := strings.TrimSpace(phoneB)
	if a == "" || b == "" {
		return ""
	}
	dt := normalizeDateToCompact(dateRaw)
	if dt == "" {
		return ""
	}
	if lessOrEqualNumericString(a, b) {
		return a + "-" + b + "-" + dt
	}
	return b + "-" + a + "-" + dt
}

func (s *server) importFeedbackToHistory(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		methodNotAllowed(w)
		return
	}
	db := s.bizDB()
	schema := ""
	if s.externalDB == nil {
		schema = strings.TrimSpace(runtimeConfig.ExternalMySQL.Database)
		if schema == "" {
			schema = "wxzdb"
		}
	}

	tbl := func(name string) string {
		if schema == "" {
			return "`" + name + "`"
		}
		return "`" + schema + "`.`" + name + "`"
	}

	rows, err := db.Query(`SELECT id, feedback_content, feedback_userId, feedback_time, mid, feedback_username FROM ` + tbl("feedback"))
	if err != nil {
		internalError(w, err)
		return
	}
	defer rows.Close()

	imported := 0
	skipped := 0
	failed := 0
	failedExamples := make([]string, 0, 10)
	appendFailedExample := func(sourceID, reason string) {
		if len(failedExamples) >= 10 {
			return
		}
		failedExamples = append(failedExamples, fmt.Sprintf("source_feedback_id=%s: %s", sourceID, reason))
	}

	for rows.Next() {
		var sourceFeedbackID, content, userID, feedbackTimeRaw, mid, userName string
		if err := rows.Scan(&sourceFeedbackID, &content, &userID, &feedbackTimeRaw, &mid, &userName); err != nil {
			failed++
			appendFailedExample("(scan_row)", err.Error())
			continue
		}

		var mappedFeedbackID int64
		if err := db.QueryRow(`SELECT feedback_id FROM `+tbl("feedback2nb_tab_grjd_feedback_history")+` WHERE source_feedback_id = ?`, sourceFeedbackID).Scan(&mappedFeedbackID); err == nil {
			skipped++
			continue
		}

		var jfhm, ddhm, jgrq sql.NullString
		if err := db.QueryRow(`SELECT jfhm, ddhm, jgrq FROM `+tbl("grjdmxjg_za")+` WHERE id = ? LIMIT 1`, mid).Scan(&jfhm, &ddhm, &jgrq); err != nil {
			failed++
			appendFailedExample(sourceFeedbackID, "lookup grjdmxjg_za failed: "+err.Error())
			continue
		}

		clueID := composeClueID(jfhm.String, ddhm.String, jgrq.String)
		if clueID == "" {
			skipped++
			continue
		}

		feedbackTime := time.Now()
		if parsed, err := time.Parse("2006-01-02 15:04:05", strings.TrimSpace(feedbackTimeRaw)); err == nil {
			feedbackTime = parsed
		}

		result, err := db.Exec(`
			INSERT INTO `+tbl("nb_tab_grjd_feedback_history")+` (clue_id, feedback_content, feedback_userId, feedback_username, remark, feedback_time)
			VALUES (?, ?, ?, ?, '', ?)`,
			clueID, content, userID, userName, feedbackTime,
		)
		if err != nil {
			failed++
			appendFailedExample(sourceFeedbackID, "insert feedback_history failed: "+err.Error())
			continue
		}

		newFeedbackID, idErr := result.LastInsertId()
		if idErr != nil {
			failed++
			appendFailedExample(sourceFeedbackID, "read last insert id failed: "+idErr.Error())
			continue
		}

		if _, err := db.Exec(`
			INSERT INTO `+tbl("feedback2nb_tab_grjd_feedback_history")+` (source_feedback_id, feedback_id)
			VALUES (?, ?)
			ON DUPLICATE KEY UPDATE feedback_id = VALUES(feedback_id)`, sourceFeedbackID, newFeedbackID); err != nil {
			failed++
			appendFailedExample(sourceFeedbackID, "insert mapping failed: "+err.Error())
			continue
		}

		imported++
	}

	if err := rows.Err(); err != nil {
		internalError(w, err)
		return
	}

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data: map[string]interface{}{
			"source_table":    "feedback",
			"target_table":    "nb_tab_grjd_feedback_history",
			"imported":        imported,
			"skipped":         skipped,
			"failed":          failed,
			"failed_examples": failedExamples,
		},
		TraceID: traceID(),
	})
}

