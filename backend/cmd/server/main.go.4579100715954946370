func normalizeScope(scope string) string {
	val := strings.ToLower(strings.TrimSpace(scope))
	switch val {
	case "all", "day", "single":
		return val
	default:
		return "single"
	}
}

func dateToIDSuffix(day string) (string, error) {
	trimmed := strings.TrimSpace(day)
	if trimmed == "" {
		return "", errors.New("empty date")
	}
	t, err := time.Parse("2006-01-02", trimmed)
	if err != nil {
		return "", errors.New("invalid date format, expected YYYY-MM-DD")
	}
	return t.Format("20060102"), nil
}

func trimSummary(text string) string {
	r := []rune(strings.TrimSpace(text))
	if len(r) <= 80 {
		return string(r)
	}
	return string(r[:80]) + "..."
}

func (s *server) buildDialogueSnapshot(scope, focusID, day string) (string, string, string, error) {
	if scope == "single" {
		cmdOut, err := s.buildSingleDialogueSnapshot(focusID)
		if err != nil {
			return "", "", "", err
		}
		return cmdOut, "案件快照（受限字段）", "read_case_snapshot.go", nil
	}

	rows, workflow, err := s.loadCanonicalSummariesWithState("")
	if err != nil {
		return "", "", "", err
	}

	filtered := make([]summaryRow, 0, len(rows))
	title := "全量线索聚合快照"
	if scope == "day" {
		suffix, err := dateToIDSuffix(day)
		if err != nil {
			return "", "", "", err
		}
		title = "指定日期线索聚合快照(" + day + ")"
		for _, item := range rows {
			_, _, dt, ok := splitID(item.ID)
			if ok && dt == suffix {
				filtered = append(filtered, item)
			}
		}
	} else {
		filtered = rows
	}

	if len(filtered) == 0 {
		emptyData := map[string]interface{}{
			"scope": scope,
			"date":  day,
			"total": 0,
			"note":  "no clue data in current scope",
		}
		buf, _ := json.Marshal(emptyData)
		return string(buf), title, "in-process-aggregator", nil
	}

	typeCounter := map[string]int{}
	levelCounter := map[string]int{}
	scoreSum := 0.0
	highRiskCount := 0
	top := filtered[0]
	for _, item := range filtered {
		typeCounter[item.Type]++
		level := strings.TrimSpace(workflow[item.ID].Level.String)
		if level == "" {
			level = "未标注"
		}
		levelCounter[level]++
		scoreSum += item.Score
		if item.Score >= 0.9 {
			highRiskCount++
		}
		if item.Score > top.Score {
			top = item
		}
	}

	sampled := make([]map[string]interface{}, 0, 10)
	sorted := make([]summaryRow, len(filtered))
	copy(sorted, filtered)
	slices.SortFunc(sorted, func(a, b summaryRow) int {
		if a.Score == b.Score {
			return cmp.Compare(a.ID, b.ID)
		}
		if a.Score > b.Score {
			return -1
		}
		return 1
	})
	for i := 0; i < len(sorted) && i < 10; i++ {
		item := sorted[i]
		sampled = append(sampled, map[string]interface{}{
			"type":    item.Type,
			"level":   workflow[item.ID].Level.String,
			"score":   item.Score,
			"summary": trimSummary(item.Summary),
		})
	}

	snapshotData := map[string]interface{}{
		"scope":              scope,
		"date":               day,
		"total":              len(filtered),
		"high_risk_count":    highRiskCount,
		"avg_score":          scoreSum / float64(len(filtered)),
		"type_distribution":  typeCounter,
		"level_distribution": levelCounter,
		"top_risk_case": map[string]interface{}{
			"type":    top.Type,
			"level":   workflow[top.ID].Level.String,
			"score":   top.Score,
			"summary": trimSummary(top.Summary),
		},
		"samples_top_score": sampled,
	}

	buf, _ := json.Marshal(snapshotData)
	return string(buf), title, "in-process-aggregator", nil
}

func (s *server) buildSingleDialogueSnapshot(clueID string) (string, error) {
	canonical := canonicalID(strings.TrimSpace(clueID))
	if canonical == "" {
		return "", errors.New("focus_id required for single scope")
	}
	reversed := reverseID(canonical)

	var item struct {
		Type    string
		Score   float64
		Summary string
	}
	if err := s.db.QueryRow(
		`SELECT type, score, summary FROM nb_tab_grjd_summary WHERE id IN (?, ?) ORDER BY update_time DESC LIMIT 1`,
		canonical, reversed,
	).Scan(&item.Type, &item.Score, &item.Summary); err != nil {
		if errors.Is(err, sql.ErrNoRows) {
			return "", errors.New("clue not found")
		}
		return "", err
	}

	var level sql.NullString
	_ = s.bizDB().QueryRow(
		`SELECT level FROM `+s.bizTable("nb_tab_grjd_workflow_state")+` WHERE id IN (?, ?) LIMIT 1`,
		canonical, reversed,
	).Scan(&level)

	out := map[string]interface{}{
		"type":    item.Type,
		"level":   level.String,
		"score":   item.Score,
		"summary": trimSummary(item.Summary),
	}
	buf, _ := json.Marshal(out)
	return string(buf), nil
}

func (s *server) callDeepseekDialogue(userContent, systemPrompt string) (string, error) {
	apiBase := envOrDefault("DEEPSEEK_API_BASE", "https://api.deepseek.com/v1")
	model := envOrDefault("DEEPSEEK_MODEL_NAME", "deepseek-chat")
	apiKey := strings.TrimSpace(envOrDefault("DEEPSEEK_API_KEY", ""))
	if apiKey == "" {
		return "", errors.New("missing DEEPSEEK_API_KEY")
	}

	payload := map[string]interface{}{
		"model": model,
		"messages": []map[string]string{
			{"role": "system", "content": systemPrompt},
			{"role": "user", "content": userContent},
		},
		"temperature": 0.2,
	}
	body, _ := json.Marshal(payload)
	req, err := http.NewRequest(http.MethodPost, strings.TrimRight(apiBase, "/")+"/chat/completions", bytes.NewReader(body))
	if err != nil {
		return "", err
	}
	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("Authorization", "Bearer "+apiKey)

	client := &http.Client{Timeout: 25 * time.Second}
	resp, err := client.Do(req)
	if err != nil {
		return "", err
	}
	defer resp.Body.Close()

	if resp.StatusCode >= 300 {
		respBody, _ := io.ReadAll(resp.Body)
		return "", fmt.Errorf("llm status: %d body: %s", resp.StatusCode, strings.TrimSpace(string(respBody)))
	}

	var decoded struct {
		Choices []struct {
			Message struct {
				Content string `json:"content"`
			} `json:"message"`
		} `json:"choices"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&decoded); err != nil {
		return "", err
	}
	if len(decoded.Choices) == 0 {
		return "", errors.New("empty llm choices")
	}
	return strings.TrimSpace(decoded.Choices[0].Message.Content), nil
}

func (s *server) friendlyDialogueError(err error) string {
	errText := err.Error()
	base := "外部模型调用失败，已返回本地兜底结论：建议提升核查优先级并追加回访。"

	switch {
	case strings.Contains(errText, "missing DEEPSEEK_API_KEY"):
		return base + " 原因：未配置 API Key，请检查 config/prism-config.json 的 llm.api_key 或环境变量 DEEPSEEK_API_KEY。"
	case strings.Contains(errText, "llm status: 401"):
		return base + " 原因：API Key 无效或已过期（401）。请更新 llm.api_key。"
	case strings.Contains(errText, "llm status: 403"):
		return base + " 原因：当前账号无该模型权限（403）。请检查模型权限或更换 model_name。"
	case strings.Contains(errText, "llm status: 429"):
		return base + " 原因：请求过频或额度不足（429）。请稍后重试并检查配额。"
	case strings.Contains(errText, "Client.Timeout"):
		return base + " 原因：调用超时。请检查网络连通性或稍后重试。"
	default:
		return base + " 原因：" + errText
	}
}

