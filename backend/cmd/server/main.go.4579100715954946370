           WHEN CHAR_LENGTH(TRIM(CAST(dt AS CHAR))) = 8
           THEN CONCAT(
             SUBSTRING(TRIM(CAST(dt AS CHAR)), 1, 4), '-',
             SUBSTRING(TRIM(CAST(dt AS CHAR)), 5, 2), '-',
             SUBSTRING(TRIM(CAST(dt AS CHAR)), 7, 2)
           )
           WHEN CHAR_LENGTH(TRIM(CAST(dt AS CHAR))) >= 10
           THEN SUBSTRING(TRIM(CAST(dt AS CHAR)), 1, 10)
           ELSE ''
         END,
         ''
       ) AS data_date
  FROM nb_tab_grjd_summary
 WHERE id IN (?, ?)
 ORDER BY update_time DESC
 LIMIT 1`, canonical, reversed)

	var item summaryRow
	if err := row.Scan(
		&item.ID, &item.Type, &item.Msisdn1, &item.Msisdn2, &item.Cnt, &item.CntDt, &item.Summary,
		&item.Score, &item.Qklx, &item.Label2, &item.UserID, &item.UserName, &item.Status,
		&item.UpdateTime, &item.DataDate,
	); err != nil {
		if errors.Is(err, sql.ErrNoRows) {
			return nil, nil
		}
		return nil, err
	}
	item.Msisdn1, item.Msisdn2 = canonicalPair(item.Msisdn1, item.Msisdn2)
	item.ID = canonicalID(item.ID)
	return &item, nil
}

func (s *server) ensureWorkflowRows(ids []string) error {
	tx, err := s.bizDB().Begin()
	if err != nil {
		return err
	}
	defer func() {
		if err != nil {
			_ = tx.Rollback()
		}
	}()

	stmt, err := tx.Prepare(`INSERT INTO ` + s.bizTable("nb_tab_grjd_workflow_state") + ` (id, status) VALUES (?, '待核查') ON DUPLICATE KEY UPDATE id=id`)
	if err != nil {
		return err
	}
	defer stmt.Close()

	for _, id := range ids {
		if _, err := stmt.Exec(id); err != nil {
			return err
		}
	}
	return tx.Commit()
}

func (s *server) loadWorkflowMap() (map[string]workflowState, error) {
	rows, err := s.bizDB().Query(`SELECT id, status, level, remark, mark_tag, distribute FROM ` + s.bizTable("nb_tab_grjd_workflow_state"))
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	result := map[string]workflowState{}
	for rows.Next() {
		var item workflowState
		if err := rows.Scan(&item.ID, &item.Status, &item.Level, &item.Remark, &item.MarkTag, &item.Distribute); err != nil {
			return nil, err
		}
		result[item.ID] = item
	}
	return result, rows.Err()
}

func (s *server) loadWorkflowMapByIDs(ids []string) (map[string]workflowState, error) {
	result := map[string]workflowState{}
	if len(ids) == 0 {
		return result, nil
	}
	placeholders := strings.Repeat("?,", len(ids))
	placeholders = strings.TrimSuffix(placeholders, ",")
	args := make([]interface{}, 0, len(ids))
	for _, id := range ids {
		args = append(args, id)
	}
	rows, err := s.bizDB().Query(
		`SELECT id, status, level, remark, mark_tag, distribute FROM `+s.bizTable("nb_tab_grjd_workflow_state")+` WHERE id IN (`+placeholders+`)`,
		args...,
	)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	for rows.Next() {
		var item workflowState
		if err := rows.Scan(&item.ID, &item.Status, &item.Level, &item.Remark, &item.MarkTag, &item.Distribute); err != nil {
			return nil, err
		}
		result[item.ID] = item
	}
	return result, rows.Err()
}

func (s *server) upsertWorkflowAction(id string, action string, value string) error {
	allowed := map[string]bool{"feedback": true, "remark": true, "mark": true}
	if !allowed[action] {
		return errors.New("unsupported action")
	}

	if action == "feedback" {
		content := strings.TrimSpace(value)
		if content == "" {
			return errors.New("feedback content required")
		}

		tx, err := s.bizDB().Begin()
		if err != nil {
			return err
		}
		defer func() {
			if err != nil {
				_ = tx.Rollback()
			}
		}()

		if _, err = tx.Exec(`INSERT INTO `+s.bizTable("nb_tab_grjd_workflow_state")+` (id, status) VALUES (?, '待核查') ON DUPLICATE KEY UPDATE id=id`, id); err != nil {
			return err
		}
		if _, err = tx.Exec(`INSERT INTO `+s.bizTable("nb_tab_grjd_feedback_history")+` (clue_id, feedback_content, feedback_userId, feedback_username, remark, feedback_time) VALUES (?, ?, ?, ?, ?, NOW())`, id, content, "system", "系统", ""); err != nil {
			return err
		}
		if _, err = tx.Exec(`UPDATE `+s.bizTable("nb_tab_grjd_workflow_state")+` SET status='已反馈', updated_at=NOW() WHERE id=?`, id); err != nil {
			return err
		}
		return tx.Commit()
	}

	if _, err := s.bizDB().Exec(`INSERT INTO `+s.bizTable("nb_tab_grjd_workflow_state")+` (id, status) VALUES (?, '待核查') ON DUPLICATE KEY UPDATE id=id`, id); err != nil {
		return err
	}

	var query string
	switch action {
	case "remark":
		query = `UPDATE ` + s.bizTable("nb_tab_grjd_workflow_state") + ` SET remark=? WHERE id=?`
	case "mark":
		query = `UPDATE ` + s.bizTable("nb_tab_grjd_workflow_state") + ` SET mark_tag=? WHERE id=?`
	}
	_, err := s.bizDB().Exec(query, value, id)
	return err
}
