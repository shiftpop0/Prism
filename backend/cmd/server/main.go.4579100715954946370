func canonicalPair(msisdn1, msisdn2 string) (string, string) {
	if lessOrEqualNumericString(msisdn1, msisdn2) {
		return msisdn1, msisdn2
	}
	return msisdn2, msisdn1
}

func (s *server) initMySQL() error {
	if err := s.validateExternalDBConfig(); err != nil {
		return err
	}

	dsn := strings.TrimSpace(runtimeConfig.MySQL.DSN)
	if dsn == "" {
		return errors.New("mysql.dsn is required in prism-config.json")
	}

	db, err := sql.Open("mysql", dsn)
	if err != nil {
		return err
	}

	db.SetMaxOpenConns(20)
	db.SetMaxIdleConns(5)
	db.SetConnMaxLifetime(30 * time.Minute)

	if err := db.Ping(); err != nil {
		return err
	}

	log.Println("mysql connected")
	s.db = db

	externalDSN := strings.TrimSpace(runtimeConfig.ExternalMySQL.DSN)
	if strings.TrimSpace(externalDSN) != "" {
		externalDB, err := sql.Open("mysql", externalDSN)
		if err == nil {
			externalDB.SetMaxOpenConns(20)
			externalDB.SetMaxIdleConns(5)
			externalDB.SetConnMaxLifetime(30 * time.Minute)
			if pingErr := externalDB.Ping(); pingErr == nil {
				s.externalDB = externalDB
				log.Println("external mysql connected")
			} else {
				log.Printf("external mysql ping failed, fallback to sdata db: %v", pingErr)
			}
		} else {
			log.Printf("external mysql open failed, fallback to sdata db: %v", err)
		}
	}

	if err := s.ensureMessageAndSummaryTables(); err != nil {
		return err
	}
	if err := s.ensureWorkflowTable(); err != nil {
		return err
	}
	if err := s.ensureDistributeTable(); err != nil {
		return err
	}
	if err := s.ensureFeedbackHistoryTable(); err != nil {
		return err
	}
	if err := s.ensureFeedbackMappingTable(); err != nil {
		return err
	}
	if err := s.ensureZaFeedbackBitNormalized(); err != nil {
		return err
	}
	if err := s.syncFeedbackStatusFromHistory(); err != nil {
		return err
	}
	return nil
}

func (s *server) bizDB() *sql.DB {
	if s.externalDB != nil {
		return s.externalDB
	}
	return s.db
}

func (s *server) bizSchemaName() string {
	if s.externalDB != nil {
		return ""
	}
	schema := strings.TrimSpace(runtimeConfig.ExternalMySQL.Database)
	if schema == "" {
		schema = "wxzdb"
	}
	return schema
}

func (s *server) bizTable(name string) string {
	schema := s.bizSchemaName()
	if schema == "" {
		return "`" + name + "`"
	}
	return "`" + schema + "`.`" + name + "`"
}

func (s *server) allowedTablesSet(dbKey string) map[string]bool {
	var raw []string
	switch dbKey {
	case "sdata":
		raw = runtimeConfig.DBTableWhitelist.Sdata
	case "wxzdb":
		raw = runtimeConfig.DBTableWhitelist.Wxzdb
	default:
		return map[string]bool{}
	}
	set := make(map[string]bool, len(raw))
	for _, name := range raw {
		trimmed := strings.TrimSpace(name)
		if trimmed == "" {
			continue
		}
		set[trimmed] = true
	}
	return set
}

func (s *server) isTableAllowed(dbKey, tableName string) bool {
	allowed := s.allowedTablesSet(dbKey)
	if len(allowed) == 0 {
		return true
	}
	return allowed[tableName]
}

