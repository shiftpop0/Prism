func (s *server) dialogueMessage(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost || !strings.HasSuffix(r.URL.Path, "/messages") {
		methodNotAllowed(w)
		return
	}

	var req struct {
		Role    string `json:"role"`
		Content string `json:"content"`
		FocusID string `json:"focus_id"`
		Scope   string `json:"scope"`
		Date    string `json:"date"`
	}
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		badRequest(w, "invalid body")
		return
	}
	if strings.TrimSpace(req.Content) == "" {
		badRequest(w, "content required")
		return
	}

	di := dialogueInput{FocusID: req.FocusID, Scope: req.Scope, Date: req.Date}
	scope, err := validateDialogueInput(di)
	if err != nil {
		badRequest(w, err.Error())
		return
	}

	snapshot, citationTitle, citationSource, err := s.buildDialogueSnapshot(scope, req.FocusID, req.Date)
	if err != nil {
		internalError(w, err)
		return
	}
	systemPrompt := buildDialogueSystemPrompt(scope, req.Date, snapshot)

	answer, err := s.callDeepseekDialogue(req.Content, systemPrompt)
	if err != nil {
		log.Printf("dialogue llm call failed: %v", err)
		answer = s.friendlyDialogueError(err)
	}

	writeJSON(w, http.StatusOK, apiResponse{
		Code:    "0",
		Message: "OK",
		Data: map[string]interface{}{
			"answer": answer,
			"citations": []map[string]string{
				{
					"evidence_id": "evd_7788",
					"title":       citationTitle,
					"source":      citationSource,
				},
			},
			"safety_flags": []string{},
		},
		TraceID: traceID(),
	})
}

type dialogueInput struct {
	FocusID string
	Scope   string
	Date    string
}

func validateDialogueInput(di dialogueInput) (string, error) {
	scope := normalizeScope(di.Scope)
	if scope == "single" && strings.TrimSpace(di.FocusID) == "" {
		return "", errors.New("focus_id required for single scope")
	}
	if scope == "day" && strings.TrimSpace(di.Date) == "" {
		return "", errors.New("date required for day scope (YYYY-MM-DD)")
	}
	return scope, nil
}

func buildDialogueSystemPrompt(scope, day, snapshot string) string {
	tpl := strings.TrimSpace(runtimeConfig.Dialogue.SystemPromptTemplate)
	if tpl == "" {
		tpl = "你是研判助手Agent。你只能使用快照中的字段(type,level,score,summary)及聚合指标输出结论，不得臆造。\n分析范围: {{scope}}\n指定日期: {{day}}\n分析快照(JSON): {{snapshot}}"
	}

	dayValue := strings.TrimSpace(day)
	if dayValue == "" {
		dayValue = "-"
	}
	scopeValue := strings.TrimSpace(scope)
	if scopeValue == "" {
		scopeValue = "single"
	}
	snapshotValue := strings.TrimSpace(snapshot)
	if snapshotValue == "" {
		snapshotValue = "{}"
	}

	systemPrompt := strings.ReplaceAll(tpl, "{{scope}}", scopeValue)
	systemPrompt = strings.ReplaceAll(systemPrompt, "{{day}}", dayValue)
	systemPrompt = strings.ReplaceAll(systemPrompt, "{{snapshot}}", snapshotValue)
	return systemPrompt
}

